# Copy this file to .env before starting.
# For production, replace every value marked with (!) with a strong secret.

# PostgreSQL credentials
KC_DB_NAME=keycloak
KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=keycloak123        # (!) use a strong password in production

# Host port Keycloak is exposed on (container always listens on 8080 internally).
# Must match the port in KC_HOSTNAME below.
KC_HTTP_HOST_PORT=8081

# Keycloak public hostname — must match the URL clients use to reach Keycloak.
# Local:      http://localhost:8081
# Production: https://auth.example.com  (no port needed when using 443)
KC_HOSTNAME=http://localhost:8081

# Bootstrap admin account — only created on first start if no admin exists yet.
# (!) Rotate or remove this account after the initial production setup.
KC_BOOTSTRAP_ADMIN_USERNAME=sindit
KC_BOOTSTRAP_ADMIN_PASSWORD=sindit123       # (!) use a strong password in production

# Host interface the HTTP port binds to.
# 0.0.0.0   = all interfaces (local dev — browser-accessible directly)
# 127.0.0.1 = loopback only (production — reverse proxy on same host)
KC_HTTP_BIND=0.0.0.0
