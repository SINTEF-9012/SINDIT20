

@prefix samm: <urn:samm:org.eclipse.esmf.samm:meta-model:2.1.0#> .
@prefix samm-c: <urn:samm:org.eclipse.esmf.samm:characteristic:2.1.0#> .
@prefix samm-e: <urn:samm:org.eclipse.esmf.samm:entity:2.1.0#> .
@prefix unit: <urn:samm:org.eclipse.esmf.samm:unit:2.1.0#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <urn:samm:sindit.sintef.no:1.0.0#> .
@prefix samm-u: <urn:samm:org.eclipse.esmf.samm:unit:2.1.0#> .

:isActive a samm:Property ;
   samm:description "Whether the api is active"@en ;
   samm:characteristic samm-c:Boolean .

:DataspaceManagement a samm:Entity ;
   samm:description "A node representing the Dataspace Management protocol"@en ;
   samm:properties ( :isActive :authenticationKeyPath :authenticationType :endpoint :dataspaceDescription :sinditApiBaseUrl :sinditServiceUser :sinditServiceUserPasswordPath :dataspaceAssets ) .

:dataspaceAssets a samm:Property ;
   samm:description "List of SINDIT KG node URIs (assets/asset properties) currently published into this dataspace's EDC catalog"@en ;
   samm:characteristic samm-c:Text .

:authenticationKeyPath a samm:Property ;
   samm:description "Path to the vault where the EDC management API key is stored"@en ;
   samm:characteristic samm-c:Text .

:dataspaceDescription a samm:Property ;
   samm:description "Description of the dataspace management node"@en ;
   samm:characteristic samm-c:Text .

:endpoint a samm:Property ;
   samm:description "Management API endpoint"@en ;
   samm:characteristic samm-c:Text .

:authenticationType a samm:Property ;
   samm:description "Type of authentication method"@en ;
   samm:characteristic samm-c:Text ;
   samm:exampleValue "tokenbased" .

:sinditApiBaseUrl a samm:Property ;
   samm:description "Public URL of the SINDIT API reachable from the EDC data plane (used as the baseUrl of published HTTP assets)"@en ;
   samm:characteristic samm-c:Text ;
   samm:exampleValue "http://sindit:9017" .

:sinditServiceUser a samm:Property ;
   samm:description "SINDIT service user used to mint the bearer token consumed by the EDC data plane"@en ;
   samm:characteristic samm-c:Text .

:sinditServiceUserPasswordPath a samm:Property ;
   samm:description "Path to the vault entry holding the password for sinditServiceUser"@en ;
   samm:characteristic samm-c:Text .
